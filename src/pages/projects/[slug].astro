---
/**
 * 项目详情页
 */
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import { formatDate } from '@lib/utils';

const base = import.meta.env.BASE_URL;

function withBase(path: string): string {
  if (path.startsWith('http')) return path;
  return base + path.replace(/^\//, '');
}

export async function getStaticPaths() {
  const projects = await getCollection('projects');

  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, description, date, role, company, status, techStack, cover, demoUrl, repoUrl, tags } =
  project.data;

const statusMap = {
  completed: { label: '已完成', class: 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400' },
  'in-progress': { label: '进行中', class: 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400' },
  planning: { label: '规划中', class: 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400' },
  archived: { label: '已归档', class: 'bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400' },
};
const currentStatus = statusMap[status || 'completed'];
---

<BaseLayout title={title} description={description} image={cover}>
  <article class="container-custom py-12">
    <!-- 返回链接 -->
    <a
      href={withBase('/projects')}
      class="mb-6 inline-flex items-center gap-1 text-sm text-slate-500 hover:text-primary-600 dark:text-slate-400 dark:hover:text-primary-400"
    >
      ← 返回项目列表
    </a>

    <!-- 封面图 -->
    {
      cover && (
        <div class="mb-8 overflow-hidden rounded-xl">
          <img
            src={cover}
            alt={title}
            class="h-64 w-full object-cover md:h-80"
          />
        </div>
      )
    }

    <div class="mx-auto max-w-3xl">
      <!-- 头部信息 -->
      <header class="mb-8">
        <div class="mb-4 flex items-center gap-3">
          <h1 class="text-3xl font-bold text-slate-900 dark:text-white md:text-4xl">
            {title}
          </h1>
          <span class={`rounded-full px-3 py-1 text-sm font-medium ${currentStatus.class}`}>
            {currentStatus.label}
          </span>
        </div>

        <p class="text-lg text-slate-600 dark:text-slate-400">
          {description}
        </p>

        <!-- 元信息 -->
        <div class="mt-6 flex flex-wrap gap-4 text-sm text-slate-500 dark:text-slate-400">
          <div class="flex items-center gap-1.5">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
              />
            </svg>
            <time datetime={date.toISOString()}>{formatDate(date)}</time>
          </div>
          {
            role && (
              <div class="flex items-center gap-1.5">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                  />
                </svg>
                {role}
                {company && ` @ ${company}`}
              </div>
            )
          }
        </div>

        <!-- 技术栈 -->
        {
          techStack && techStack.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {techStack.map((tech) => (
                <span class="tag">{tech}</span>
              ))}
            </div>
          )
        }

        <!-- 链接按钮 -->
        <div class="mt-6 flex flex-wrap gap-3">
          {
            demoUrl && (
              <a href={demoUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
                <svg class="mr-1.5 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                  />
                </svg>
                在线演示
              </a>
            )
          }
          {
            repoUrl && (
              <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="btn-secondary">
                <svg class="mr-1.5 h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                  <path
                    fill-rule="evenodd"
                    d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0012 2z"
                    clip-rule="evenodd"
                  />
                </svg>
                GitHub
              </a>
            )
          }
        </div>
      </header>

      <!-- 文章正文 -->
      <div class="prose prose-slate dark:prose-invert max-w-none">
        <Content />
      </div>

      <!-- 标签 -->
      {
        tags && tags.length > 0 && (
          <div class="mt-12 border-t border-slate-200 pt-8 dark:border-slate-700">
            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <a href={withBase(`/tags/${tag}`)} class="tag">
                  #{tag}
                </a>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </article>
</BaseLayout>