---
/**
 * 首页
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/post/PostCard.astro';
import ProjectCard from '@components/project/ProjectCard.astro';
import ToolCard from '@components/tool/ToolCard.astro';
import { getAllPosts, getFeaturedProjects, getFeaturedTools } from '@lib/content';
import { getCategories } from '@data/categories';
import { siteConfig } from '@data/site';

const base = import.meta.env.BASE_URL;

function withBase(path: string): string {
  if (path.startsWith('http')) return path;
  return base + path.replace(/^\//, '');
}

const posts = await getAllPosts();
const featuredProjects = await getFeaturedProjects(3);
const featuredTools = await getFeaturedTools(6);
const categories = getCategories();
---

<BaseLayout>
  <!-- Hero 区域 -->
  <section class="border-b border-slate-200 bg-gradient-to-b from-white to-slate-50 dark:border-slate-800 dark:from-slate-950 dark:to-slate-900">
    <div class="container-custom py-16 md:py-24">
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="mb-6 text-4xl font-bold leading-tight text-slate-900 dark:text-white md:text-5xl">
          你好，我是 <span class="gradient-text">{siteConfig.author}</span>
        </h1>
        <p class="mb-8 text-lg text-slate-600 dark:text-slate-400 md:text-xl">
          {siteConfig.slogan}
        </p>
        <p class="mb-8 text-slate-500 dark:text-slate-400">
          {siteConfig.bio}
        </p>
        <div class="flex items-center justify-center gap-4">
          <a href={withBase('/posts')} class="btn-primary">
            开始阅读
          </a>
          <a href={withBase('/resume')} class="btn-secondary">
            查看简历
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 最新文章 -->
  <section class="py-16">
    <div class="container-custom">
      <div class="mb-8 flex items-center justify-between">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white">最新文章</h2>
        <a href="/posts" class="link text-sm">查看全部 →</a>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {posts.slice(0, 6).map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    </div>
  </section>

  <!-- 分类快捷入口 -->
  <section class="border-t border-slate-200 bg-slate-50 py-16 dark:border-slate-800 dark:bg-slate-900">
    <div class="container-custom">
      <h2 class="mb-8 text-2xl font-bold text-slate-900 dark:text-white">分类</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {categories.slice(0, 4).map((cat) => (
          <a
            href={withBase(`/categories/${cat.slug}`)}
            class="card group"
          >
            <div class="flex items-center gap-3">
              <span class="text-2xl">{cat.icon}</span>
              <div>
                <h3 class="font-semibold text-slate-900 group-hover:text-primary-600 dark:text-white dark:group-hover:text-primary-400">
                  {cat.name}
                </h3>
                <p class="text-sm text-slate-500 dark:text-slate-400">
                  {cat.description.slice(0, 30)}...
                </p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 精选项目 -->
  <section class="py-16">
    <div class="container-custom">
      <div class="mb-8 flex items-center justify-between">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white">项目经验</h2>
        <a href={withBase('/projects')} class="link text-sm">查看全部 →</a>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {featuredProjects.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </div>
  </section>

  <!-- 实用工具 -->
  <section class="border-t border-slate-200 bg-slate-50 py-16 dark:border-slate-800 dark:bg-slate-900">
    <div class="container-custom">
      <div class="mb-8 flex items-center justify-between">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white">实用工具</h2>
        <a href={withBase('/tools')} class="link text-sm">查看全部 →</a>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {featuredTools.map((tool) => (
          <ToolCard tool={tool} />
        ))}
      </div>
    </div>
  </section>

  <!-- 关于 -->
  <section class="py-16">
    <div class="container-custom">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="mb-8 text-2xl font-bold text-slate-900 dark:text-white">关于我</h2>
        <p class="mb-8 text-slate-600 dark:text-slate-400">
          了解更多关于我的信息、技术方向和经验分享。
        </p>
        <a href="/about" class="btn-secondary">了解更多</a>
      </div>
    </div>
  </section>
</BaseLayout>