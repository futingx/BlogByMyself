---
/**
 * 分类列表页
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCategories } from '@data/categories';
import { getAllCategories } from '@lib/content';

const categoryMeta = getCategories();
const categoryCounts = await getAllCategories();

// 合并数据
const categories = categoryMeta.map((cat) => {
  const countData = categoryCounts.find((c) => c.category === cat.slug);
  return {
    ...cat,
    count: countData?.count || 0,
  };
}).filter((cat) => cat.count > 0);
---

<BaseLayout title="分类" description="所有文章分类">
  <section class="container-custom py-12">
    <div class="mb-8">
      <h1 class="mb-2 text-3xl font-bold text-slate-900 dark:text-white">分类</h1>
      <p class="text-slate-600 dark:text-slate-400">
        共 {categories.length} 个分类
      </p>
    </div>

    {
      categories.length > 0 ? (
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {categories.map((cat) => (
            <a
              href={`/categories/${cat.slug}`}
              class="card group"
            >
              <div class="flex items-center gap-4">
                <span class="text-3xl">{cat.icon}</span>
                <div class="flex-1">
                  <h3 class="font-semibold text-slate-900 group-hover:text-primary-600 dark:text-white dark:group-hover:text-primary-400">
                    {cat.name}
                  </h3>
                  <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">
                    {cat.description}
                  </p>
                  <p class="mt-2 text-xs text-primary-600 dark:text-primary-400">
                    {cat.count} 篇文章
                  </p>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="py-12 text-center">
          <p class="text-slate-500 dark:text-slate-400">暂无分类</p>
        </div>
      )
    }
  </section>
</BaseLayout>