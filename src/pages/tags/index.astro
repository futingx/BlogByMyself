---
/**
 * 标签云页
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import { getAllTags } from '@lib/content';
import { getTagCloudStyle } from '@lib/taxonomy';

const tags = await getAllTags();
const maxCount = Math.max(...tags.map((t) => t.count), 1);
---

<BaseLayout title="标签" description="所有文章标签">
  <section class="container-custom py-12">
    <div class="mb-8">
      <h1 class="mb-2 text-3xl font-bold text-slate-900 dark:text-white">标签</h1>
      <p class="text-slate-600 dark:text-slate-400">
        共 {tags.length} 个标签
      </p>
    </div>

    {
      tags.length > 0 ? (
        <div class="flex flex-wrap gap-4 py-8">
          {tags.map(({ tag, count }) => {
            const style = getTagCloudStyle({ tag, count, slug: tag }, maxCount);
            return (
              <a
                href={`/tags/${tag}`}
                class="rounded-lg border border-slate-200 bg-white px-4 py-2 transition-all hover:border-primary-300 hover:shadow-md dark:border-slate-700 dark:bg-slate-800 dark:hover:border-primary-700"
                style={`font-size: ${style.fontSize}; opacity: ${style.opacity}`}
              >
                <span class="font-medium text-primary-600 dark:text-primary-400">#{tag}</span>
                <span class="ml-1 text-slate-400">({count})</span>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="py-12 text-center">
          <p class="text-slate-500 dark:text-slate-400">暂无标签</p>
        </div>
      )
    }
  </section>
</BaseLayout>