---
/**
 * 基础布局组件
 * 所有页面的公共布局基础
 */
import SEO from '@components/seo/SEO.astro';
import Header from '@components/common/Header.astro';
import Footer from '@components/common/Footer.astro';
import '@styles/global.css';

const base = import.meta.env.BASE_URL;

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  article?: boolean;
}

const { title, description, image, type = 'website', publishedTime, article = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={base + 'favicon.svg'} />
    <SEO
      title={title}
      description={description}
      image={image}
      type={type}
      publishedTime={publishedTime}
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- 阅读进度条（仅文章页启用） -->
    {
      article && (
        <div id="reading-progress" style="width: 0%"></div>
      )
    }
  </body>
</html>

{
  article && (
    <script>
      // 阅读进度条
      const progressBar = document.getElementById('reading-progress');
      const articleEl = document.querySelector('article');

      if (progressBar && articleEl) {
        window.addEventListener('scroll', () => {
          const articleTop = articleEl.offsetTop;
          const articleHeight = articleEl.offsetHeight;
          const windowHeight = window.innerHeight;
          const scrolled = window.scrollY;

          const start = articleTop - windowHeight;
          const end = articleTop + articleHeight - windowHeight;
          const progress = Math.min(Math.max((scrolled - start) / (end - start) * 100, 0), 100);

          progressBar.style.width = `${progress}%`;
        });
      }
    </script>
  )
}
