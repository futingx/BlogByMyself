---
/**
 * 工具卡片组件
 */
import type { Tool } from '@lib/content';

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
const { title, description, type, tags, url, pricing } = tool.data;

const typeMap = {
  'dev-tool': { label: '开发工具', icon: '🔧' },
  productivity: { label: '效率工具', icon: '⚡' },
  'ai-tool': { label: 'AI 工具', icon: '🤖' },
  'browser-extension': { label: '浏览器插件', icon: '🌐' },
  other: { label: '其他', icon: '📦' },
};

const pricingMap = {
  free: { label: '免费', class: 'text-green-600 dark:text-green-400' },
  freemium: { label: '免费/付费', class: 'text-amber-600 dark:text-amber-400' },
  paid: { label: '付费', class: 'text-slate-500' },
};

const currentType = typeMap[type || 'dev-tool'];
const currentPricing = pricingMap[pricing || 'free'];
---

<article class="card group">
  <div class="flex flex-col gap-3">
    <!-- 类型标签 -->
    <div class="flex items-center gap-2">
      <span class="text-lg">{currentType.icon}</span>
      <span class="text-sm text-slate-500 dark:text-slate-400">{currentType.label}</span>
      <span class={`ml-auto text-xs font-medium ${currentPricing.class}`}>
        {currentPricing.label}
      </span>
    </div>

    <!-- 标题 -->
    <h3 class="text-lg font-semibold">
      {
        url ? (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-900 hover:text-primary-600 dark:text-white dark:hover:text-primary-400 transition-colors flex items-center gap-1"
          >
            {title}
            <svg class="h-3.5 w-3.5 opacity-0 transition-opacity group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        ) : (
          <span class="text-slate-900 dark:text-white">{title}</span>
        )
      }
    </h3>

    <!-- 描述 -->
    <p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-2">
      {description}
    </p>

    <!-- 标签 -->
    {
      tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {tags.map((tag) => (
            <span class="tag text-xs">
              #{tag}
            </span>
          ))}
        </div>
      )
    }
  </div>
</article>