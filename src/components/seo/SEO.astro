---
/**
 * SEO 组件
 * 用于生成页面元信息和 Open Graph 标签
 */
import { siteConfig } from '@data/site';
import { generateTitle, generateDescription } from '@lib/seo';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
  canonical?: string;
}

const {
  title,
  description,
  image = '/og-image.jpg',
  type = 'website',
  publishedTime,
  modifiedTime,
  tags,
  canonical,
} = Astro.props;

const siteTitle = generateTitle(title);
const siteDescription = generateDescription(description);
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site || siteConfig.url).href;
const ogImage = new URL(image, Astro.site || siteConfig.url).href;
---

<!-- 基础 Meta -->
<title>{siteTitle}</title>
<meta name="description" content={siteDescription} />
<meta name="author" content={siteConfig.author} />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:title" content={siteTitle} />
<meta property="og:description" content={siteDescription} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={siteConfig.name} />
<meta property="og:image" content={ogImage} />
<meta property="og:locale" content={siteConfig.language} />

{type === 'article' && publishedTime && (
  <meta property="article:published_time" content={publishedTime} />
)}
{type === 'article' && modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime} />
)}
{type === 'article' && tags && tags.map((tag) => (
  <meta property="article:tag" content={tag} />
))}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={siteTitle} />
<meta name="twitter:description" content={siteDescription} />
<meta name="twitter:image" content={ogImage} />

<!-- RSS -->
<link rel="alternate" type="application/rss+xml" title={siteConfig.name} href="/rss.xml" />

<!-- 主题色 -->
<meta name="theme-color" content="#2563eb" />
<meta name="color-scheme" content="light dark" />

<!-- 禁止爬虫索引（草稿页等可设置） -->
<!-- <meta name="robots" content="noindex, nofollow" /> -->
