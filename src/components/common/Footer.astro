---
/**
 * 页脚组件
 */
import { siteConfig, footerConfig } from '@data/site';
import { footerNavigation } from '@data/navigation';
---

<footer class="mt-20 border-t border-slate-200 bg-slate-50 dark:border-slate-800 dark:bg-slate-950">
  <div class="container-custom py-12">
    <div class="grid gap-8 md:grid-cols-4">
      <!-- 站点信息 -->
      <div class="md:col-span-2">
        <a
          href="/"
          class="flex items-center gap-2 text-xl font-bold text-slate-900 dark:text-white mb-4"
        >
          <span class="text-2xl">✦</span>
          <span>{siteConfig.name}</span>
        </a>
        <p class="text-slate-600 dark:text-slate-400 max-w-md">
          {siteConfig.description}
        </p>
        <!-- 社交链接 -->
        <div class="mt-4 flex gap-4">
          {
            siteConfig.socials.github && (
              <a
                href={siteConfig.socials.github}
                target="_blank"
                rel="noopener noreferrer"
                class="text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white transition-colors"
                aria-label="GitHub"
              >
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                  <path
                    fill-rule="evenodd"
                    d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0012 2z"
                    clip-rule="evenodd"
                  />
                </svg>
              </a>
            )
          }
          {
            siteConfig.socials.twitter && (
              <a
                href={siteConfig.socials.twitter}
                target="_blank"
                rel="noopener noreferrer"
                class="text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white transition-colors"
                aria-label="Twitter / X"
              >
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                  <path
                    d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                  />
                </svg>
              </a>
            )
          }
          {
            siteConfig.socials.rss && (
              <a
                href={siteConfig.socials.rss}
                class="text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white transition-colors"
                aria-label="RSS 订阅"
              >
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                  <path
                    d="M6.18 15.64a2.18 2.18 0 012.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 012.18-2.18M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 002 12.93V10.1z"
                  />
                </svg>
              </a>
            )
          }
        </div>
      </div>

      <!-- 快速链接 -->
      <div>
        <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-slate-900 dark:text-white">
          快速链接
        </h3>
        <ul class="space-y-2">
          {
            footerNavigation.map((item) => (
              <li>
                <a
                  href={item.href}
                  target={item.external ? '_blank' : undefined}
                  rel={item.external ? 'noopener noreferrer' : undefined}
                  class="text-sm text-slate-600 hover:text-primary-600 dark:text-slate-400 dark:hover:text-primary-400 transition-colors"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- 联系方式 -->
      <div>
        <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-slate-900 dark:text-white">
          联系方式
        </h3>
        <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
          {
            siteConfig.email && (
              <li>
                <a
                  href={`mailto:${siteConfig.email}`}
                  class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
                >
                  {siteConfig.email}
                </a>
              </li>
            )
          }
          {
            siteConfig.socials.github && (
              <li>
                <a
                  href={siteConfig.socials.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
                >
                  GitHub
                </a>
              </li>
            )
          }
        </ul>
      </div>
    </div>

    <!-- 底部版权 -->
    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-slate-200 pt-8 text-sm text-slate-500 dark:border-slate-800 dark:text-slate-400 md:flex-row">
      <p>
        © {footerConfig.copyrightYear} {siteConfig.name}. {footerConfig.shortDescription}
      </p>
      {
        footerConfig.ICP && (
          <p>
            <a
              href="https://beian.miit.gov.cn/"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
            >
              {footerConfig.ICP}
            </a>
          </p>
        )
      }
    </div>
  </div>
</footer>
