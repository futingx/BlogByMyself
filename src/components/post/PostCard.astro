---
/**
 * 文章卡片组件
 */
import type { Post } from '@lib/content';
import { formatDate } from '@lib/utils';

interface Props {
  post: Post;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const { title, description, date, tags, category, cover } = post.data;
---

<article
  class:list={[
    'group card',
    featured && 'col-span-full md:col-span-2',
  ]}
>
  {
    cover && (
      <a href={`/posts/${post.slug}`} class="block overflow-hidden rounded-lg mb-4">
        <img
          src={cover}
          alt={title}
          class="h-48 w-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
        />
      </a>
    )
  }

  <div class="flex flex-col gap-3">
    <!-- 分类标签 -->
    <div class="flex items-center gap-2 text-sm">
      <a
        href={`/categories/${category}`}
        class="text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300 font-medium transition-colors"
      >
        {category}
      </a>
      <span class="text-slate-300 dark:text-slate-600">·</span>
      <time datetime={date.toISOString()} class="text-slate-500 dark:text-slate-400">
        {formatDate(date)}
      </time>
    </div>

    <!-- 标题 -->
    <h3 class="text-xl font-semibold">
      <a
        href={`/posts/${post.slug}`}
        class="text-slate-900 hover:text-primary-600 dark:text-white dark:hover:text-primary-400 transition-colors line-clamp-2"
      >
        {title}
      </a>
    </h3>

    <!-- 描述 -->
    <p class="text-slate-600 dark:text-slate-400 line-clamp-2">
      {description}
    </p>

    <!-- 标签 -->
    {
      tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-1">
          {tags.slice(0, 3).map((tag) => (
            <a
              href={`/tags/${tag}`}
              class="tag"
            >
              #{tag}
            </a>
          ))}
          {tags.length > 3 && (
            <span class="tag opacity-60">+{tags.length - 3}</span>
          )}
        </div>
      )
    }
  </div>
</article>
