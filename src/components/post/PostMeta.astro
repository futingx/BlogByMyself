---
/**
 * 文章元信息组件
 */
import type { Post } from '@lib/content';
import { formatDate } from '@lib/utils';

interface Props {
  post: Post;
  showReadingTime?: boolean;
}

const { post, showReadingTime = true } = Astro.props;
const { title, description, date, updated, tags, category, readingTime } = post.data;
---

<div class="flex flex-wrap items-center gap-4 text-sm text-slate-500 dark:text-slate-400">
  <!-- 日期 -->
  <div class="flex items-center gap-1.5">
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
      />
    </svg>
    <time datetime={date.toISOString()}>
      {formatDate(date)}
    </time>
  </div>

  <!-- 更新日期 -->
  {
    updated && (
      <div class="flex items-center gap-1.5">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
          />
        </svg>
        <time datetime={updated.toISOString()}>
          更新于 {formatDate(updated)}
        </time>
      </div>
    )
  }

  <!-- 阅读时长 -->
  {
    showReadingTime && readingTime && (
      <div class="flex items-center gap-1.5">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
          />
        </svg>
        <span>{readingTime} 分钟阅读</span>
      </div>
    )
  }

  <!-- 分类 -->
  <a
    href={`/categories/${category}`}
    class="flex items-center gap-1.5 rounded-full bg-slate-100 px-2.5 py-0.5 text-slate-600 hover:bg-primary-100 hover:text-primary-700 dark:bg-slate-800 dark:text-slate-300 dark:hover:bg-primary-900/30 dark:hover:text-primary-400 transition-colors"
  >
    <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"
      />
    </svg>
    {category}
  </a>

  <!-- 标签 -->
  {
    tags && tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <a
            href={`/tags/${tag}`}
            class="tag text-xs"
          >
            #{tag}
          </a>
        ))}
      </div>
    )
  }
</div>
