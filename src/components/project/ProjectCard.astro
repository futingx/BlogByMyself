---
/**
 * 项目卡片组件
 */
import type { Project } from '@lib/content';
import { formatDate } from '@lib/utils';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const { title, description, date, techStack, cover, status, demoUrl, repoUrl } = project.data;

const statusMap = {
  completed: { label: '已完成', class: 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400' },
  'in-progress': { label: '进行中', class: 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400' },
  planning: { label: '规划中', class: 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400' },
  archived: { label: '已归档', class: 'bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400' },
};

const currentStatus = statusMap[status || 'completed'];
---

<article class="card group">
  {
    cover && (
      <a href={`/projects/${project.slug}`} class="block overflow-hidden rounded-lg mb-4">
        <img
          src={cover}
          alt={title}
          class="h-40 w-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
        />
      </a>
    )
  }

  <div class="flex flex-col gap-3">
    <!-- 标题和状态 -->
    <div class="flex items-start justify-between gap-2">
      <h3 class="text-lg font-semibold">
        <a
          href={`/projects/${project.slug}`}
          class="text-slate-900 hover:text-primary-600 dark:text-white dark:hover:text-primary-400 transition-colors"
        >
          {title}
        </a>
      </h3>
      <span class={`shrink-0 rounded-full px-2 py-0.5 text-xs font-medium ${currentStatus.class}`}>
        {currentStatus.label}
      </span>
    </div>

    <!-- 描述 -->
    <p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-2">
      {description}
    </p>

    <!-- 技术栈 -->
    {
      techStack && techStack.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {techStack.slice(0, 4).map((tech) => (
            <span class="rounded bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600 dark:bg-slate-700 dark:text-slate-300">
              {tech}
            </span>
          ))}
          {techStack.length > 4 && (
            <span class="text-xs text-slate-400">+{techStack.length - 4}</span>
          )}
        </div>
      )
    }

    <!-- 链接 -->
    <div class="flex items-center gap-3 pt-2 border-t border-slate-100 dark:border-slate-700">
      <a
        href={`/projects/${project.slug}`}
        class="text-sm font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300 transition-colors"
      >
        查看详情 →
      </a>
      {
        repoUrl && (
          <a
            href={repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="ml-auto text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors"
            aria-label="GitHub 仓库"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                fill-rule="evenodd"
                d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0012 2z"
                clip-rule="evenodd"
              />
            </svg>
          </a>
        )
      }
      {
        demoUrl && (
          <a
            href={demoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors"
            aria-label="在线演示"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
              />
            </svg>
          </a>
        )
      }
    </div>
  </div>
</article>
